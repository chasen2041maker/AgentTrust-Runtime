{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenttrust.dev/schemas/policy-pack-v1.schema.json",
  "title": "AgentTrust Policy Pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pack", "policy", "policy_digest"],
  "properties": {
    "schema_version": {"const": "agenttrust.policy-pack/v1"},
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"},
        "version": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,63}$"}
      }
    },
    "policy": {"$ref": "#/$defs/policy"},
    "policy_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  },
  "$defs": {
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_version", "project_root", "mode", "final_answer", "verification", "approvals", "rules"],
      "properties": {
        "policy_version": {"const": "agenttrust.policy/v1"},
        "project_root": {"type": "string"},
        "mode": {"type": "string"},
        "final_answer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["on_incomplete"],
          "properties": {"on_incomplete": {"enum": ["warn", "deny_completion", "require_revision"]}}
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {"mode": {"enum": ["fallback", "groundguard_required"]}}
        },
        "approvals": {
          "type": "object",
          "additionalProperties": false,
          "required": ["default_ttl_seconds"],
          "properties": {"default_ttl_seconds": {"type": "integer", "minimum": 1}}
        },
        "rules": {"type": "array", "items": {"$ref": "#/$defs/rule"}},
        "hooks": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pre_tool"],
          "properties": {"pre_tool": {"type": "array", "items": {"$ref": "#/$defs/hook"}}}
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "tool", "effect", "reason"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "tool": {"type": "string", "minLength": 1},
        "effect": {"enum": ["allow", "ask", "deny"]},
        "reason": {"type": "string"},
        "paths": {"type": "array", "items": {"type": "string"}},
        "command_patterns": {"type": "array", "items": {"type": "string"}},
        "argv_patterns": {"type": "array", "items": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}}
      }
    },
    "hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "when", "action", "reason"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "when": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tool"],
          "properties": {"tool": {"type": "string", "minLength": 1}, "path_glob": {"type": "string"}}
        },
        "action": {"const": "deny"},
        "reason": {"type": "string"}
      }
    }
  }
}
